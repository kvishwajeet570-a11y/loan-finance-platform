generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// USER MODEL
// ========================================

model User {
  id String @id @default(cuid())

  name String

  email String @unique

  phoneNo String @unique

  password String

  otp String?

  otpExpiry DateTime?

  isVerified Boolean @default(false)

  isBlocked Boolean @default(false)

  role String @default("user")

  profileImage String?

  panCardImage String?

  aadharCardImage String?

  selfieImage String?

  refreshToken String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  loans LoanApplication[]

  wallet Wallet?

  referral Referral?

  recharges Recharge[]

  supportTickets SupportTicket[]

  fastagRecharges FastagRecharge[]

  electricityBills ElectricityBill[]

  securityLogs SecurityLog[]

  activities UserActivity[]

  notifications Notification[]
}

// ========================================
// LOAN APPLICATION
// ========================================

model LoanApplication {
  id String @id @default(cuid())

  fullName String

  email String

  phone String

  loanType String

  amount Float

  dob String?

  panNo String?

  aadhaarNo String?

  status String @default("pending")

  interestRate Float?

  tenureMonths Int?

  monthlyEMI Float?

  purpose String?

  address String?

  city String?

  state String?

  zipCode String?

  monthlyIncome Float?

  employmentType String?

  remarks String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  userId String?

  user User? @relation(fields: [userId], references: [id])

  commissions Commission[]

  emiPayments EMIPayment[]
}

// ========================================
// CONTACT MESSAGE
// ========================================

model ContactMessage {
  id String @id @default(cuid())

  name String

  email String

  phone String

  subject String?

  message String

  createdAt DateTime @default(now())
}

// ========================================
// ACHIEVEMENT
// ========================================

model Achievement {
  id String @id @default(cuid())

  title String

  description String

  reward Float @default(0)

  userId String?

  createdAt DateTime @default(now())
}

// ========================================
// COMMISSION
// ========================================

model Commission {
  id String @id @default(cuid())

  amount Float

  userId String

  loanId String

  loan LoanApplication @relation(fields: [loanId], references: [id])

  createdAt DateTime @default(now())
}

// ========================================
// WALLET
// ========================================

model Wallet {
  id String @id @default(cuid())

  balance Float @default(0)

  cashback Float @default(0)

  rewardBalance Float @default(0)

  totalEarnings Float @default(0)

  userId String @unique

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  transactions Transaction[]

  walletHistory WalletHistory[]
}

// ========================================
// TRANSACTION
// ========================================

model Transaction {
  id String @id @default(cuid())

  type String

  amount Float

  status String @default("success")

  description String?

  transactionId String? @unique

  paymentMethod String?

  walletId String

  wallet Wallet @relation(fields: [walletId], references: [id])

  createdAt DateTime @default(now())
}

// ========================================
// COUPON
// ========================================

model Coupon {
  id String @id @default(cuid())

  code String @unique

  discount Float

  minAmount Float?

  maxDiscount Float?

  maxUsage Int @default(100)

  usedCount Int @default(0)

  isActive Boolean @default(true)

  expiryDate DateTime

  createdAt DateTime @default(now())
}

// ========================================
// REFERRAL
// ========================================

model Referral {
  id String @id @default(cuid())

  referralCode String @unique

  rewardAmount Float @default(0)

  totalReferrals Int @default(0)

  totalEarnings Float @default(0)

  userId String @unique

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  referralHistory ReferralHistory[]
}

// ========================================
// RECHARGE
// ========================================

model Recharge {
  id String @id @default(cuid())

  mobileNumber String

  operator String

  amount Float

  rechargeType String

  planDetails String?

  status String @default("pending")

  transactionRef String?

  userId String

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ========================================
// NOTIFICATION
// ========================================

model Notification {
  id String @id @default(cuid())

  title String

  message String

  type String? @default("general")

  userId String

  user User @relation(fields: [userId], references: [id])

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
}

// ========================================
// SUPPORT TICKET
// ========================================

model SupportTicket {
  id String @id @default(cuid())

  subject String

  message String

  priority String @default("medium")

  status String @default("open")

  adminReply String?

  userId String

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ========================================
// EMI PAYMENT
// ========================================

model EMIPayment {
  id String @id @default(cuid())

  amount Float

  paymentDate DateTime @default(now())

  paymentMethod String?

  status String @default("paid")

  loanId String

  loan LoanApplication @relation(fields: [loanId], references: [id])
}

// ========================================
// FASTAG RECHARGE
// ========================================

model FastagRecharge {
  id String @id @default(cuid())

  vehicleNo String

  provider String

  amount Float

  status String @default("success")

  userId String

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ========================================
// ELECTRICITY BILL
// ========================================

model ElectricityBill {
  id String @id @default(cuid())

  consumerNo String

  provider String

  amount Float

  status String @default("paid")

  userId String

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ========================================
// JOB APPLICATION
// ========================================

model JobApplication {
  id String @id @default(cuid())

  fullName String

  email String

  phone String

  position String?

  resumeUrl String?

  status String @default("pending")

  createdAt DateTime @default(now())
}

// ========================================
// REVENUE ANALYTICS
// ========================================

model RevenueAnalytics {
  id String @id @default(cuid())

  totalRevenue Float

  totalUsers Int

  totalLoans Int

  totalTransactions Int

  createdAt DateTime @default(now())
}

// ========================================
// LEADERBOARD
// ========================================

model Leaderboard {
  id String @id @default(cuid())

  userName String

  totalPoints Int @default(0)

  totalSales Float @default(0)

  createdAt DateTime @default(now())
}

// ========================================
// USER ACTIVITY
// ========================================

model UserActivity {
  id String @id @default(cuid())

  activity String

  userId String

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ========================================
// SECURITY LOG
// ========================================

model SecurityLog {
  id String @id @default(cuid())

  action String

  ipAddress String?

  deviceInfo String?

  userId String

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ========================================
// RECHARGE PLAN
// ========================================

model RechargePlan {
  id String @id @default(cuid())

  operator String

  amount Float

  validity String

  benefits String

  createdAt DateTime @default(now())
}

// ========================================
// REFERRAL HISTORY
// ========================================

model ReferralHistory {
  id String @id @default(cuid())

  referredUserId String

  rewardAmount Float

  referralId String

  referral Referral @relation(fields: [referralId], references: [id])

  createdAt DateTime @default(now())
}

// ========================================
// WALLET HISTORY
// ========================================

model WalletHistory {
  id String @id @default(cuid())

  balance Float

  walletId String

  wallet Wallet @relation(fields: [walletId], references: [id])

  createdAt DateTime @default(now())
}

// ========================================
// NOTIFICATION SETTINGS
// ========================================

model NotificationSettings {
  id String @id @default(cuid())

  emailAlerts Boolean @default(true)

  smsAlerts Boolean @default(true)

  pushAlerts Boolean @default(true)

  createdAt DateTime @default(now())
}
